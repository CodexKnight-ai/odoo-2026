generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ExpenseType {
  TOLL
  PARKING
  MAINTENANCE
  OTHER
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(DRIVER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id                 Int           @id @default(autoincrement())
  registrationNumber String        @unique
  name               String
  type               String
  maxLoadCapacity    Decimal       @db.Decimal(12, 2)
  odometer           Decimal       @default(0) @db.Decimal(14, 2)
  acquisitionCost    Decimal       @default(0) @db.Decimal(14, 2)
  status             VehicleStatus @default(AVAILABLE)
  region             String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  trips              Trip[]
  maintenanceLogs    MaintenanceLog[]
  fuelLogs           FuelLog[]
  expenses           Expense[]

  @@index([status])
  @@index([region])
}

model Driver {
  id                Int          @id @default(autoincrement())
  name              String
  licenseNumber     String       @unique
  licenseCategory   String
  licenseExpiryDate DateTime
  contactNumber     String
  safetyScore       Decimal      @default(100) @db.Decimal(5, 2)
  status            DriverStatus @default(AVAILABLE)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  trips             Trip[]

  @@index([status])
  @@index([licenseExpiryDate])
}

model Trip {
  id              Int        @id @default(autoincrement())
  source          String
  destination     String
  cargoWeight     Decimal    @db.Decimal(12, 2)
  plannedDistance Decimal    @db.Decimal(12, 2)
  actualDistance  Decimal?   @db.Decimal(12, 2)
  revenue         Decimal    @default(0) @db.Decimal(14, 2)
  finalOdometer   Decimal?   @db.Decimal(14, 2)
  status          TripStatus @default(DRAFT)
  dispatchedAt    DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  vehicleId       Int
  driverId        Int
  vehicle         Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Restrict)
  driver          Driver     @relation(fields: [driverId], references: [id], onDelete: Restrict)
  fuelLogs        FuelLog[]
  expenses        Expense[]

  @@index([status])
  @@index([vehicleId, status])
  @@index([driverId, status])
}

model MaintenanceLog {
  id          Int               @id @default(autoincrement())
  description String
  status      MaintenanceStatus @default(OPEN)
  scheduledAt DateTime          @default(now())
  completedAt DateTime?
  cost        Decimal           @default(0) @db.Decimal(14, 2)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  vehicleId   Int
  vehicle     Vehicle           @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, status])
  @@index([status])
}

model FuelLog {
  id        Int      @id @default(autoincrement())
  liters    Decimal  @db.Decimal(12, 2)
  cost      Decimal  @db.Decimal(14, 2)
  date      DateTime @default(now())
  odometer  Decimal? @db.Decimal(14, 2)
  createdAt DateTime @default(now())
  vehicleId Int
  tripId    Int?
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip      Trip?    @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([vehicleId, date])
}

model Expense {
  id          Int         @id @default(autoincrement())
  type        ExpenseType
  amount      Decimal     @db.Decimal(14, 2)
  description String?
  date        DateTime    @default(now())
  createdAt   DateTime    @default(now())
  vehicleId   Int
  tripId      Int?
  vehicle     Vehicle     @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trip        Trip?       @relation(fields: [tripId], references: [id], onDelete: SetNull)

  @@index([vehicleId, date])
  @@index([type])
}
